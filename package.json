{
  "name": "tablet-kiosk",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "Weather kiosk application for Samsung Galaxy Tab S8 Ultra",
  "author": "",
  "license": "ISC",
  "homepage": "https://github.com/relsam-atinersier/tablet-kiosk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relsam-atinersier/tablet-kiosk.git"
  },
  "bugs": {
    "url": "https://github.com/relsam-atinersier/tablet-kiosk/issues"
  },
  "keywords": [],
  "main": "dist/index.html",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "dev:legacy": "vite --open /index-legacy.html",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"**/*.css\"",
    "stylelint:fix": "stylelint \"**/*.css\" --fix",
    "type-check": "tsc --noEmit",
    "analyze:lit": "lit-analyzer 'src/**/*.ts'",
    "validate": "run-s lint:fix stylelint:fix lint stylelint analyze:lit test build",
    "deploy": "./deploy.sh",
    "deploy:list": "./deploy.sh -l",
    "deploy:clean": "./deploy.sh -c",
    "knip": "knip"
  },
  "dependencies": {
    "@lit/context": "1.1.6",
    "lit": "3.3.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.7.3",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "10.1.0",
    "eslint-plugin-lit": "2.2.1",
    "eslint-plugin-wc": "3.1.0",
    "happy-dom": "20.8.8",
    "jsdom": "29.0.1",
    "knip": "6.0.6",
    "lit-analyzer": "2.0.3",
    "npm-run-all": "4.1.5",
    "only-allow": "1.2.2",
    "stylelint": "17.6.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vitest": "4.1.0"
  }
}
