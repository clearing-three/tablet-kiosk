{
  "name": "tablet-kiosk",
  "version": "1.0.0",
  "description": "Weather kiosk application for Samsung Galaxy Tab S8 Ultra",
  "type": "module",
  "main": "dist/index.html",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,css,html}\"",
    "type-check": "tsc --noEmit",
    "deploy": "./deploy.sh",
    "deploy:list": "./deploy.sh -l",
    "deploy:clean": "./deploy.sh -c"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relsam-atinersier/tablet-kiosk.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/relsam-atinersier/tablet-kiosk/issues"
  },
  "homepage": "https://github.com/relsam-atinersier/tablet-kiosk#readme",
  "devDependencies": {
    "@types/node": "24.5.2",
    "@typescript-eslint/eslint-plugin": "8.44.0",
    "@typescript-eslint/parser": "8.44.0",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "28.1.0",
    "prettier": "3.6.2",
    "typescript": "5.9.2",
    "vite": "7.1.6",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "date-fns": "4.1.0"
  }
}
