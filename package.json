{
  "name": "tablet-kiosk",
  "version": "1.0.0",
  "description": "Weather kiosk application for Samsung Galaxy Tab S8 Ultra",
  "type": "module",
  "main": "dist/index.html",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"**/*.css\"",
    "stylelint:fix": "stylelint \"**/*.css\" --fix",
    "format": "prettier --write \"**/*.{ts,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,css,html}\"",
    "type-check": "tsc --noEmit",
    "validate": "run-s format lint:fix stylelint:fix lint stylelint test build",
    "deploy": "./deploy.sh",
    "deploy:list": "./deploy.sh -l",
    "deploy:clean": "./deploy.sh -c",
    "knip": "knip"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relsam-atinersier/tablet-kiosk.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/relsam-atinersier/tablet-kiosk/issues"
  },
  "homepage": "https://github.com/relsam-atinersier/tablet-kiosk#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.1",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "29.0.0",
    "knip": "5.87.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "stylelint": "17.4.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  }
}
